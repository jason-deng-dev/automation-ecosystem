    {
      "id": "X5BT3gH23HzUdT1Y2bOjR",
      "type": "text",
      "x": 3401.6359387721427,
      "y": 565.4234650213589,
      "width": 607.2813761085065,
      "height": 218.96208001814523,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "at",
      "roundness": null,
      "seed": 703569266,
      "version": 1160,
      "versionNonce": 1337607154,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1774591233248,
      "link": null,
      "locked": false,
      "text": "TranslatePress, translates products as they are\ndisplayed/accessed by users\n- updates Wordpress db for the translated products\n\nIf user searches for product, and we only have x number of\nproducts to show, Rakuten API fetches for 10-x products \n- we display x number of products and provide option to user to\nwait 2-3 minutes while we provide more products (ensure sale\noppurtunity is not lost)\n",
      "fontSize": 17.516966401451626,
      "fontFamily": 8,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "TranslatePress, translates products as they are displayed/accessed by users\n- updates Wordpress db for the translated products\n\nIf user searches for product, and we only have x number of products to show, Rakuten API fetches for 10-x products \n- we display x number of products and provide option to user to wait 2-3 minutes while we provide more products (ensure sale oppurtunity is not lost)\n",
      "autoResize": false,
      "lineHeight": 1.25
    },
