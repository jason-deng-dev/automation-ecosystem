      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Auth handling (1)\n\nif auth expires, process fails and logs/info is updated to shared folder, which the dashboard picks up",
      "autoResize": false,
      "lineHeight": 1.25
    },
