      "id": "ysYxt5Nqx0Tt8rx9H6TRk",
      "type": "text",
      "x": 3651.4233999446838,
      "y": -69.86667590688774,
      "width": 422.9649553926784,
      "height": 205.10293490649502,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
