      ],
      "updated": 1774587294297,
      "link": null,
      "locked": false,
      "text": "Cron job that according to config makes post on xhs of certain types\n -if type is race use races.json \n    -ask Claude API will race (not in post_history) will perform best\n -create context / send to Claude API to get a formatted post json response\n -use playwright to post to Rednote\n    - stores authentication via auth.json\nwatches config file for change to update cron jobs",
      "fontSize": 14.347191102929706,
      "fontFamily": 8,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Cron job that according to config makes post on xhs of certain types\n -if type is race use races.json \n    -ask Claude API will race (not in post_history) will perform best\n -create context / send to Claude API to get a formatted post json response\n -use playwright to post to Rednote\n    - stores authentication via auth.json\nwatches config file for change to update cron jobs",
      "autoResize": false,
      "lineHeight": 1.25
    },
